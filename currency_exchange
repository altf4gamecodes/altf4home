<style>
/* 1. Terminal Dashboard Layout */
.terminal-dashboard {
    display: flex;
    gap: 20px;
    margin: 25px 0;
    align-items: stretch;
}

/* 2. CRT System Glow */
[class*="rte"] {
    animation: monitorPulse 4s infinite alternate ease-in-out !important;
}
@keyframes monitorPulse {
    0% { text-shadow: 0 0 2px rgba(0, 255, 0, 0.2); }
    100% { text-shadow: 0 0 5px rgba(0, 255, 0, 0.4); }
}

/* 3. Ticker Board (Left) */
.market-ticker {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 15px;
    border: 1px solid #39ff14;
    background: rgba(0, 255, 0, 0.02);
    width: 440px;
    flex-shrink: 0;
}

.ticker-row {
    display: flex;
    justify-content: space-between;
    padding: 10px;
    border-bottom: 1px dashed rgba(57, 255, 20, 0.2);
    cursor: pointer;
    font-family: monospace;
    font-size: 12px;
    color: #39ff14 !important;
    transition: all 0.2s ease;
}
.ticker-row:hover {
    background: rgba(57, 255, 20, 0.1);
    color: #fff !important;
}

/* 4. The Content Terminal (Right) */
.content-terminal {
    flex-grow: 1;
    border: 1px solid #39ff14;
    background: #000;
    min-height: 500px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
}

.terminal-header {
    background: #39ff14;
    color: #000;
    font-family: monospace;
    font-size: 11px;
    font-weight: bold;
    padding: 5px 12px;
}

.terminal-body {
    padding: 20px;
    overflow-y: auto;
    max-height: 600px;
    color: #39ff14;
    font-family: monospace;
}

/* 5. Product Grid Styling */
.terminal-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 15px;
}
.mini-card {
    border: 1px solid rgba(57, 255, 20, 0.3);
    padding: 10px;
    text-align: center;
    font-size: 11px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
}
.mini-card img { 
    width: 100%; 
    height: auto; 
    margin-bottom: 8px; 
    border-bottom: 1px solid rgba(57, 255, 20, 0.2); 
}
.mini-card a { 
    color: #000; 
    text-decoration: none; 
    display: block; 
    margin-top: 10px; 
    background: #39ff14; 
    padding: 5px; 
    font-weight: bold;
}

/* 6. Dynamic Status Colors */
.stock-high { color: #39ff14; font-weight: bold; }
.stock-avg { color: #ffcc00; font-weight: bold; }
.stock-low { color: #ff3333; font-weight: bold; }

.loading-text { animation: blink 1s infinite; }
@keyframes blink { 0% { opacity: 0; } 50% { opacity: 1; } 100% { opacity: 0; } }

@media (max-width: 991px) {
    .terminal-dashboard { flex-direction: column; }
    .market-ticker { width: 100%; }
}
</style>
